# Copy this to secrets.toml and fill in real values.
# secrets.toml is gitignored — never commit real keys.

[anthropic]
api_key = "sk-ant-..."

[voyage]
api_key = "pa-..."

[supabase]
# Durable storage for team state, usage tracking, and uploads.
# Leave this whole section out for local dev (falls back to data/store.db).
# When set, the app reads/writes Supabase so data survives redeploys.
# Get both from Supabase dashboard -> Project Settings -> API.
# service_role_key is a SECRET: server-side only, never commit it.
url = "https://YOUR_PROJECT.supabase.co"
service_role_key = "eyJ..."

[google]
# Read-only Drive sync (Director -> Curation -> "Sync from Drive").
# Leave this whole section out to keep Drive sync off (button shows setup steps).
# Needs a service-account credential AND the folder shared with its email.
# Pick ONE credential form:
#
# Local dev — point at a JSON key file (gitignored):
service_account_path = "service_account.json"
#
# Streamlit Cloud — paste the key's fields inline (no files on Cloud). Either:
#   service_account_json = '''{ "type": "service_account", "project_id": "...", ... }'''
# or a nested table:
#   [google.service_account_info]
#   type = "service_account"
#   project_id = "..."
#   private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#   client_email = "qmun-drive@PROJECT.iam.gserviceaccount.com"
#   ... (all fields from the downloaded JSON)
#
# The folder must be shared (Viewer) with the service account's client_email.
shared_drive_folder_id = "FOLDER_ID_HERE"

[slack]
# Leave client_id + client_secret empty for dev mode (auto-login as dev user).
# Fill in once a Slack app is registered for the QMUN workspace.
client_id = ""
client_secret = ""
signing_secret = ""
workspace_id = "T..."
# redirect_uri MUST match the URL configured in the Slack app's OAuth Redirect URLs.
# Streamlit serves everything at root; the callback is handled in lib/auth.py via st.query_params.
redirect_uri = "http://localhost:8501"

[app]
# --- Pilot gate (active when pilot_passcode is set and Slack OAuth is not configured) ---
# Share the passcode with exec pilot users out-of-band (iMessage, in person).
# Use a long, hard-to-guess string (12+ chars). Pilot URL is publicly reachable; passcode is the only gate.
pilot_passcode = "change-me-to-a-long-string"
# Names must match exactly what users type in the sign-in form (case-insensitive).
pilot_admin_names = ["Director Name"]
pilot_exec_names = ["Exec One", "Exec Two", "Exec Three"]

# --- Slack OAuth role mapping (active once client_id + client_secret are set above) ---
admin_slack_user_ids = ["U_ADMIN_ID"]
exec_slack_user_ids = []

# --- Budget ---
budget_monthly_usd_cap = 40.0
budget_monthly_usd_warn = 35.0
