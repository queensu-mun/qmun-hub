# Copy this to secrets.toml and fill in real values.
# secrets.toml is gitignored — never commit real keys.

[anthropic]
api_key = "sk-ant-..."

[voyage]
api_key = "pa-..."

[google]
# Path to service account JSON, or paste contents inline as a multi-line string.
service_account_path = "service_account.json"
shared_drive_folder_id = "FOLDER_ID_HERE"

[slack]
# Leave client_id + client_secret empty for dev mode (auto-login as dev user).
# Fill in once a Slack app is registered for the QMUN workspace.
client_id = ""
client_secret = ""
signing_secret = ""
workspace_id = "T..."
# redirect_uri MUST match the URL configured in the Slack app's OAuth Redirect URLs.
# Streamlit serves everything at root; the callback is handled in lib/auth.py via st.query_params.
redirect_uri = "http://localhost:8501"

[app]
# --- Pilot gate (active when pilot_passcode is set and Slack OAuth is not configured) ---
# Share the passcode with exec pilot users out-of-band (iMessage, in person).
pilot_passcode = "change-me"
# Names must match exactly what users type in the sign-in form (case-insensitive).
pilot_admin_names = ["Jack Guillemette"]
pilot_exec_names = ["Jake Louhikari", "Savannah Summers"]

# --- Slack OAuth role mapping (active once client_id + client_secret are set above) ---
admin_slack_user_ids = ["U_JACK_ID", "U_JAKE_ID", "U_SAVANNAH_ID"]
exec_slack_user_ids = []

# --- Budget ---
budget_monthly_usd_cap = 40.0
budget_monthly_usd_warn = 35.0
